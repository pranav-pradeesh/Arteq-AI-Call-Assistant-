# Copy to project root as .env for docker-compose.selfhost.yml, then fill in.
# Self-host stack runs LiveKit on the box, so LIVEKIT_URL is set by compose.

ENV=production
LOG_LEVEL=INFO
HOSPITAL_ID=00000000-0000-0000-0000-000000000001
TELEPHONY_MODE=stream

# Public reachability — VPS public IP (for LiveKit WebRTC media candidates).
NODE_IP=YOUR_VPS_PUBLIC_IP
PUBLIC_BASE_URL=https://your-domain
PUBLIC_WS_URL=wss://your-domain

# Local Postgres (compose service). Pick a strong password.
POSTGRES_USER=arteq
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=arteq_hospital

# LiveKit self-hosted keys — any matching pair; used by server, sip, app, agent.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-32-chars-minimum-secret
LIVEKIT_SIP_HOST=YOUR_VPS_PUBLIC_IP
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# AI providers
SARVAM_API_KEY=
GROQ_API_KEY=
TTS_PROVIDER=sarvam
STT_PROVIDER=sarvam
DEFAULT_LANGUAGE=ml-IN

# Telephony (Plivo) + WhatsApp
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=
WHATSAPP_ENABLED=true
PLIVO_WHATSAPP_NUMBER=
WHATSAPP_FALLBACK_TO_SMS=true

# Persona
AGENT_NAME=Arya
AGENT_LANGUAGE=ml-IN

# Dashboard auth (production-strength required)
DASHBOARD_ADMIN_PASSWORD=change-me-12-chars-min
DASHBOARD_JWT_SECRET=generate-with-secrets-token_hex-32
STAFF_ALERT_PHONE=
