# Copy to project root as .env for docker-compose.selfhost.yml, then fill in.
# Self-host stack runs LiveKit on the box, so LIVEKIT_URL is set by compose.

ENV=production
LOG_LEVEL=INFO
HOSPITAL_ID=00000000-0000-0000-0000-000000000001
TELEPHONY_MODE=stream

# Public reachability — VPS public IP (for LiveKit WebRTC media candidates).
NODE_IP=YOUR_VPS_PUBLIC_IP
PUBLIC_BASE_URL=https://your-domain
PUBLIC_WS_URL=wss://your-domain

# Local Postgres (compose service). Pick a strong password.
POSTGRES_USER=arteq
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=arteq_hospital

# LiveKit self-hosted keys — any matching pair; used by server, sip, app, agent.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-32-chars-minimum-secret
LIVEKIT_SIP_HOST=YOUR_VPS_PUBLIC_IP
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# AI providers
SARVAM_API_KEY=
GROQ_API_KEY=
# Default conversational brain — OpenRouter → google/gemini-2.5-flash-lite.
# Get a key from https://openrouter.ai/keys
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
TTS_PROVIDER=sarvam
STT_PROVIDER=sarvam
DEFAULT_LANGUAGE=ml-IN

# Telephony (Plivo) + WhatsApp
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=
WHATSAPP_ENABLED=true
PLIVO_WHATSAPP_NUMBER=
WHATSAPP_FALLBACK_TO_SMS=true

# Persona
AGENT_NAME=Arya
AGENT_LANGUAGE=ml-IN

# Dashboard auth (production-strength required)
DASHBOARD_ADMIN_PASSWORD=change-me-12-chars-min
DASHBOARD_JWT_SECRET=generate-with-secrets-token_hex-32
DASHBOARD_JWT_EXPIRE_MINUTES=720
# Email for the auto-seeded super-admin account (password above)
SUPERADMIN_EMAIL=admin@arteqai.com
STAFF_ALERT_PHONE=

# Internal API key — required in production for /api/v1/outbound + campaigns.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=

# CORS — set to your dashboard origin(s); "*" is dev-only.
CORS_ORIGINS=*

# Outbound scheduler loops (defaults shown; set false to disable)
REMINDERS_ENABLED=true
REMINDER_INTERVAL_SECONDS=900
CONFIRMATIONS_ENABLED=true
CONFIRMATION_LOOP_INTERVAL_SECONDS=3600
CONFIRMATION_DAYS_MIN=6
CONFIRMATION_DAYS_MAX=8
CALLBACKS_ENABLED=true
CALLBACK_LOOP_INTERVAL_SECONDS=300
FOLLOWUPS_ENABLED=true
FOLLOWUP_LOOP_INTERVAL_SECONDS=3600
FOLLOWUP_DAYS_AFTER=3
CAMPAIGN_RESUME_ENABLED=true
CAMPAIGN_RESUME_INTERVAL_SECONDS=600

# Optional feature flags
PATIENT_RECOGNITION_ENABLED=true
AFTER_HOURS_CALLBACK_ENABLED=true
DTMF_ENABLED=true
POST_CALL_SMS_ENABLED=false

# Redis — required for live dashboard monitoring in sip mode (the agent worker
# publishes call events across processes). Leave blank to disable.
REDIS_URL=
