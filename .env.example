# ─────────────────────────────────────────────────────────────────
# Arteq Hospital Voice Agent — environment variables
# Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
ENV=dev                        # dev | production
LOG_LEVEL=INFO
PORT=8000
HOSPITAL_ID=00000000-0000-0000-0000-000000000001
TELEPHONY_MODE=stream          # stream | sip

# ── Public URLs (required for Plivo webhooks) ─────────────────────
# Set to your Render service URL after first deploy.
# On Render, RENDER_EXTERNAL_URL is injected automatically.
PUBLIC_BASE_URL=http://localhost:8000
PUBLIC_WS_URL=ws://localhost:8000

# ── Persona ───────────────────────────────────────────────────────
AGENT_NAME=Arya
AGENT_LANGUAGE=ml-IN
DEFAULT_LANGUAGE=ml-IN

# ── Sarvam AI — STT (Saarika) + TTS (Bulbul v3) ────────────────
# Get from: https://app.sarvam.ai → API Keys
SARVAM_API_KEY=your_sarvam_api_key_here
# STT model + language. Saarika TRANSCRIBES in the caller's own language/script
# (needed so Arya replies in that language). Do NOT use a "saaras" model here —
# those TRANSLATE speech to English and break per-caller language detection.
# Leave language as "unknown" for auto-detect, or pin it (e.g. ml-IN) if your
# callers are single-language and auto-detect is unreliable.
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_STT_LANGUAGE=unknown

# ── Groq — LLaMA 3.3 70B (LLM brain) ────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── LiveKit — voice agent infrastructure ──────────────────────────
# Get from: https://cloud.livekit.io → your project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# LiveKit SIP trunking (set after running POST /admin/sip/setup)
# LIVEKIT_SIP_HOST: found in LiveKit Cloud → SIP → Inbound Trunks
LIVEKIT_SIP_HOST=xx.sip.livekit.cloud
# LIVEKIT_SIP_OUTBOUND_TRUNK_ID: returned by POST /admin/sip/setup
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# ── Plivo — telephony carrier ─────────────────────────────────────
# Get from: https://console.plivo.com → Overview
PLIVO_AUTH_ID=your_plivo_auth_id
PLIVO_AUTH_TOKEN=your_plivo_auth_token
PLIVO_PHONE_NUMBER=+918047XXXXXX   # E.164 Indian DID

# ── Exotel — telephony carrier (alternative to Plivo) ─────────────
# Get from: https://my.exotel.com → Settings → API
EXOTEL_API_KEY=your_exotel_account_sid
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_PHONE_NUMBER=+9180XXXXXXXX        # ExoPhone / Virtual Number, E.164
EXOTEL_SUBDOMAIN=api.exotel.com          # or api.in.exotel.com (India region)
# Secret embedded in the webhook + WebSocket URL (Exotel sends no signature).
EXOTEL_WEBHOOK_TOKEN=
# Audio path: "sip" forwards the call to LiveKit over SIP; "websocket" makes
# Exotel's Voicebot applet stream raw 16-bit 8 kHz mono PCM to
# /ws/exotel/stream/<token>/<slug>, which we bridge into the LiveKit room.
EXOTEL_TRANSPORT=sip
# Outgoing media chunk size to Exotel — multiple of 320, 3200..100000 bytes.
EXOTEL_STREAM_CHUNK_BYTES=3200
# App/flow id (with a Voicebot applet) used for outbound WebSocket-streamed
# calls via the Exotel Connect API. Leave blank if not using outbound-over-WS.
EXOTEL_VOICEBOT_APP_ID=

# ── Database ──────────────────────────────────────────────────────
# asyncpg connection string
DATABASE_URL=postgresql://user:password@host:5432/arteq_hospital
# SSL mode: auto (require for remote, disable for localhost/docker) | require | disable
DB_SSL=auto

# ── Supabase (optional — for storage bucket TTS cache) ───────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_STORAGE_BUCKET=tts-cache

# ── Redis (optional — falls back to in-memory cache if blank) ─────
REDIS_URL=

# ── Dashboard auth ───────────────────────────────────────────────
DASHBOARD_ADMIN_PASSWORD=change_me_in_production
DASHBOARD_JWT_SECRET=change_me_in_production
DASHBOARD_JWT_EXPIRE_MINUTES=720
# Email for the auto-seeded super-admin account (password above)
SUPERADMIN_EMAIL=admin@arteqai.com

# ── Security: CORS + token abuse guard ───────────────────────────
# Comma-separated allowed browser origins. "*" = any (dev only).
# In production set to your real origins, e.g.
#   CORS_ORIGINS=https://arteq.example.com,https://admin.example.com
CORS_ORIGINS=*
# Per-IP cap on /api/v1/livekit/token requests (each spins a billable room).
TOKEN_RATE_LIMIT=12
TOKEN_RATE_WINDOW_SECONDS=60

# ── Internal API (for outbound trigger endpoints) ─────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=your_internal_api_key_here

# ── Staff alerts ──────────────────────────────────────────────────
# SMS the duty manager on bookings, cancellations, emergencies.
# Leave blank to disable.
STAFF_ALERT_PHONE=+91XXXXXXXXXX
STAFF_ALERT_ON_BOOKING=true
STAFF_ALERT_ON_EMERGENCY=true
STAFF_ALERT_ON_CANCEL=true

# ── Scheduler intervals ───────────────────────────────────────────
REMINDERS_ENABLED=true
REMINDER_INTERVAL_SECONDS=900
CONFIRMATIONS_ENABLED=true
CONFIRMATION_LOOP_INTERVAL_SECONDS=3600
CONFIRMATION_DAYS_MIN=6
CONFIRMATION_DAYS_MAX=8
CALLBACKS_ENABLED=true
CALLBACK_LOOP_INTERVAL_SECONDS=300
FOLLOWUPS_ENABLED=true
FOLLOWUP_LOOP_INTERVAL_SECONDS=3600
FOLLOWUP_DAYS_AFTER=3
# Resume campaigns whose dialing was interrupted by a restart
CAMPAIGN_RESUME_ENABLED=true
CAMPAIGN_RESUME_INTERVAL_SECONDS=600

# ── Optional feature flags ────────────────────────────────────────
POST_CALL_SMS_ENABLED=false
PATIENT_RECOGNITION_ENABLED=true
AFTER_HOURS_CALLBACK_ENABLED=true
DTMF_ENABLED=true
