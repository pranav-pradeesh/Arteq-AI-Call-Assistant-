# ─────────────────────────────────────────────────────────────────
# Arteq Hospital Voice Agent — environment variables
# Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
ENV=dev                        # dev | production
LOG_LEVEL=INFO
PORT=8000
HOSPITAL_ID=00000000-0000-0000-0000-000000000001
TELEPHONY_MODE=stream          # stream | sip

# ── Public URLs ───────────────────────────────────────────────────
# Set to your Render service URL after first deploy.
# On Render, RENDER_EXTERNAL_URL is injected automatically.
PUBLIC_BASE_URL=http://localhost:8000
PUBLIC_WS_URL=ws://localhost:8000

# ── Persona ───────────────────────────────────────────────────────
AGENT_NAME=Arya
AGENT_LANGUAGE=ml-IN
DEFAULT_LANGUAGE=ml-IN
# Artificial ambient "room tone" mixed into the caller's audio so the line
# doesn't feel dead. Fraction of full scale, 0.0–1.0. Lower = quieter; 0
# disables it (clean line). Default 0.02.
AMBIENT_NOISE_LEVEL=0.02

# ── Call runtime behaviour ────────────────────────────────────────
# Hard ceiling on a single call; the room is closed after this many seconds
# (default 600 = 10 min, far above a normal call — a safety cap against runaway cost).
MAX_CALL_DURATION_S=600
# Silence handling: after PROMPT_S of no speech Arya gently re-prompts; after
# HANGUP_S of continued silence the call is ended.
INACTIVITY_PROMPT_S=20
INACTIVITY_HANGUP_S=40

# ── Provider selection ────────────────────────────────────────────
# STT/TTS provider. Only "sarvam" is wired today; kept for future providers.
STT_PROVIDER=sarvam
TTS_PROVIDER=sarvam
# Minimum STT confidence (0–1) before a transcript is trusted.
STT_CONFIDENCE_THRESHOLD=0.55

# ── Sarvam AI — STT (Saarika/Saaras) + TTS (Bulbul v3) ────────
# Get from: https://app.sarvam.ai → API Keys
SARVAM_API_KEY=your_sarvam_api_key_here
# STT model. saarika:v2.5 is stable; saaras:v2.5 is the recommended upgrade
# (23 languages vs 11, adds codemix mode). Both use the same language codes.
SARVAM_STT_MODEL=saarika:v2.5
# STT language (BCP-47 xx-IN format). Use "unknown" for auto-detection.
# Supported language codes:
#   ml-IN  Malayalam    hi-IN  Hindi       ta-IN  Tamil
#   te-IN  Telugu       kn-IN  Kannada     bn-IN  Bengali
#   mr-IN  Marathi      gu-IN  Gujarati    pa-IN  Punjabi
#   od-IN  Odia         en-IN  English (Indian)
# saaras:v2.5 also adds: as-IN, ur-IN, sa-IN, ne-IN, mai-IN, kok-IN,
#   ks-IN, doi-IN, mni-IN, brx-IN, sat-IN, sd-IN
SARVAM_STT_LANGUAGE=unknown
# Talking speed (Bulbul TTS pace multiplier). 1.0 = natural, 1.3 = brisker.
TTS_PACE=1.0

# ── Realtime turn-taking ──────────────────────────────────────────
# How fast Arya decides the caller finished and starts replying (the EoU part of
# latency). LOWER = snappier but more risk of cutting callers off. Defaults are a
# safe balance; tune on REAL calls. For a snappier "realtime" feel try
# VAD_MIN_SILENCE=0.1 and ENDPOINTING_MIN_DELAY=0.1; raise back toward 0.2 if
# callers get cut off mid-sentence.
VAD_MIN_SILENCE=0.2            # end-of-speech silence before turn-end (s) — main dial
ENDPOINTING_MIN_DELAY=0.2     # extra wait before the LLM fires (s)
ENDPOINTING_MAX_DELAY=3.0     # cap so a slow speaker pausing isn't cut off (s)
VAD_MIN_SPEECH=0.3            # min speech to count as a turn (s) — filters noise
VAD_ACTIVATION_THRESHOLD=0.5  # Silero speech gate; don't raise (phone audio scores low)

# ── LLM brain ─────────────────────────────────────────────────────
# LLM_PROVIDER picks the PRIMARY conversational brain. A fast primary
# (gemini/openrouter/groq) keeps Sarvam as an automatic fallback if it errors.
#   gemini → Default. Google AI Studio Gemini (GOOGLE_MODEL, default
#            gemini-2.5-flash-lite) via Google's own endpoint. Low TTFT (~0.5s vs
#            Sarvam ~1.9s) AND strong Malayalam. flash-lite is the cheapest tier;
#            raise GOOGLE_MODEL to gemini-2.5-flash for higher quality. REQUIRES a
#            FUNDED Google API key (real prepaid billing or Vertex) — the free-trial
#            credit 429s every turn. If your key is unfunded use LLM_PROVIDER=
#            openrouter or sarvam. Configure via GOOGLE_API_KEY / GOOGLE_MODEL.
#   openrouter → OpenAI-compatible gateway routing to OPENROUTER_MODEL (default
#            google/gemini-2.5-flash-lite). ONE key (OPENROUTER_API_KEY) pays for any
#            hosted model, so it sidesteps the funded-Google-billing requirement of
#            direct Gemini — the fallback when a direct Google key isn't available.
#   groq   → llama-3.3-70b-versatile. Lowest TTFT but OPT-IN: needs an ACTIVE Groq
#            developer plan (currently inactive), and weaker Malayalam.
# NOTE: Sarvam-30B is NO LONGER usable as the conversational LLM (it answered terse
# one-word Malayalam turns poorly). LLM_PROVIDER=sarvam now resolves to Gemini.
# There is no automatic LLM fallback — the selected brain answers every turn.
# (Sarvam is still used for STT/Saarika and TTS/Bulbul; see SARVAM_API_KEY below.)
LLM_PROVIDER=gemini   # Google AI Studio (default); openrouter/groq also selectable
GROQ_MODEL=llama-3.3-70b-versatile   # Groq model (only when LLM_PROVIDER=groq)
LLM_MAX_TOKENS=300             # cap reply length → shorter, faster spoken replies

# ── OpenRouter — the PRIMARY brain when LLM_PROVIDER=openrouter ──
# OpenAI-compatible; one key pays for any model OpenRouter hosts.
# Get a key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model slug from https://openrouter.ai/models (provider/model form).
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# Optional attribution headers shown on OpenRouter dashboards/leaderboards.
OPENROUTER_SITE_URL=https://arteq.ai
OPENROUTER_APP_NAME=Arteq AI Call Assistant

# Google Gemini (Google AI Studio) — the brain when LLM_PROVIDER=gemini (default).
# IMPORTANT: needs a Google API key with REAL prepaid billing (or Vertex AI). The
# Google Cloud free-trial credit CANNOT pay for the Gemini API — an unfunded key
# returns 429 every turn, and there is NO fallback now, so those turns drop. Use
# LLM_PROVIDER=openrouter if you don't have funded Google billing.
# Get a key from: https://aistudio.google.com/apikey (Google AI Studio)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash-lite   # cheapest tier; use gemini-2.5-flash for higher quality

# ── Groq ──────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=groq (opt-in) and also
# used by the legacy brain module and diagnostics (run.py, tools/doctor.py).
# If blank, the agent falls back to Sarvam automatically.
# Get from: https://console.groq.com → API Keys
GROQ_API_KEY=

# ── WhatsApp — Meta Cloud API (patient notifications; no SMS) ──────
# Get from: https://developers.facebook.com → your app → WhatsApp → API Setup
# Patient confirmations/reminders use pre-approved "Utility" templates.
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_API_VERSION=v21.0
# Language code of your approved templates (e.g. en, ml, hi).
WHATSAPP_TEMPLATE_LANG=en
# Approved template names — create these in Meta Business Manager. Body
# variables {{1}},{{2}}… must match the order documented in whatsapp_service.py.
WHATSAPP_TPL_CONFIRMATION=appointment_confirmation
WHATSAPP_TPL_TOKEN_ACTIVE=token_active
WHATSAPP_TPL_REMINDER=appointment_reminder
WHATSAPP_TPL_CANCELLATION=appointment_cancellation
WHATSAPP_TPL_DOCTOR_AVAIL=doctor_availability
WHATSAPP_TPL_CALLBACK=callback_confirmation
WHATSAPP_TPL_LOCATION=hospital_location
WHATSAPP_TPL_LAB=lab_schedule

# ── LiveKit — voice agent infrastructure ──────────────────────────
# Get from: https://cloud.livekit.io → your project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
# Explicit-dispatch agent name. The worker registers under this name and the
# token endpoint dispatches to it — it MUST match between worker and token.
# Override locally (e.g. "arya-local") to isolate a dev worker from a deployed
# "arya" worker on the same LiveKit project.
LIVEKIT_DISPATCH_NAME=arya

# LiveKit SIP trunking (set after running POST /admin/sip/setup)
# LIVEKIT_SIP_HOST: found in LiveKit Cloud → SIP → Inbound Trunks
LIVEKIT_SIP_HOST=xx.sip.livekit.cloud
# LIVEKIT_SIP_OUTBOUND_TRUNK_ID: returned by POST /admin/sip/setup
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# ── Vobiz — SIP trunk provider ────────────────────────────────────
# Which carrier outbound calls (reminders/confirmations) dial through.
# "vobiz" (default, current carrier) or "plivo" (legacy).
TELEPHONY_CARRIER=vobiz
# Get from: https://vobiz.in → API Access
VOBIZ_API_KEY=your_vobiz_api_key
VOBIZ_API_SECRET=your_vobiz_api_secret
VOBIZ_PHONE_NUMBER=+918047XXXXXX         # E.164 DID assigned by Vobiz
# CIDRs that Vobiz uses to send SIP INVITE — leave blank for defaults.
VOBIZ_SIP_CIDRS=
# Vobiz routes each trunk on its OWN domain: <trunkId>.sip.vobiz.ai. Sending
# outbound to the generic sip.vobiz.ai returns 404 "Trunk Not Found". Copy your
# OUTBOUND trunk's SIP domain from the Vobiz console here, then re-run
# POST /admin/sip/vobiz/setup so the LiveKit trunk dials the right host.
VOBIZ_SIP_OUTBOUND_DOMAIN=
# Outbound callee number format Vobiz expects (E.164 per docs). Options:
#   e164 → +91XXXXXXXXXX (default)  |  cc → 91XXXXXXXXXX
#   national → 0XXXXXXXXXX          |  local → XXXXXXXXXX (10-digit)
VOBIZ_DIAL_FORMAT=e164
# SIP credentials LiveKit uses to authenticate OUTBOUND calls to Vobiz. These
# MUST match a Vobiz Credentials-List entry attached to the outbound trunk.
# Leave blank to fall back to VOBIZ_API_KEY/VOBIZ_API_SECRET (legacy).
VOBIZ_SIP_USERNAME=
VOBIZ_SIP_PASSWORD=
# Set after running POST /admin/sip/vobiz/setup
LIVEKIT_SIP_VOBIZ_OUTBOUND_TRUNK_ID=

# Vobiz call recording (opt-in — check recording storage pricing in Vobiz console).
# When enabled, recordings appear under each hospital's Calls tab in the dashboard.
# Download: https://media.vobiz.ai/v1/Account/{api_key}/Recording/{id}.mp3
VOBIZ_RECORD_CALLS=false
VOBIZ_RECORDING_FORMAT=mp3              # mp3 (smaller) | wav (higher quality)
VOBIZ_RECORDING_CHANNELS=mono          # mono | stereo (stereo splits caller/agent)

# ── Database ──────────────────────────────────────────────────────
# asyncpg connection string. The app reads DATABASE_URL directly.
#
# Managed DB (Render/Supabase/external): point this at your hosted Postgres and
# leave DB_SSL=auto.
#
# SELF-HOST (docker-compose.selfhost.yml): the bundled `postgres` container reads
# POSTGRES_USER/PASSWORD/DB below to CREATE the database, and the app connects via
# DATABASE_URL — so the user/password/db MUST match in both, and the host is the
# Docker service name `postgres` (NOT localhost). The compose file forces
# DB_SSL=disable for the app/agent automatically. Uncomment this block:
#   POSTGRES_USER=arteq
#   POSTGRES_PASSWORD=change_me_strong
#   POSTGRES_DB=arteq_hospital
#   DATABASE_URL=postgresql://arteq:change_me_strong@postgres:5432/arteq_hospital
DATABASE_URL=postgresql://user:password@host:5432/arteq_hospital
# SSL mode: auto (require for remote, disable for localhost/docker) | require | disable
DB_SSL=auto

# ── Supabase (optional — for storage bucket TTS cache) ───────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_STORAGE_BUCKET=tts-cache

# ── Redis (optional — falls back to in-memory cache if blank) ─────
# SELF-HOST: set REDIS_URL=redis://redis:6379/0 (the bundled redis service). Leave
# REDIS_PASSWORD blank — redis is only on the internal Docker network. If you DO
# set REDIS_PASSWORD, you must include it in REDIS_URL (redis://:<pw>@redis:6379/0)
# or the app can't authenticate.
REDIS_URL=
REDIS_PASSWORD=

# ── Dashboard auth ───────────────────────────────────────────────
DASHBOARD_ADMIN_PASSWORD=change_me_in_production
DASHBOARD_JWT_SECRET=change_me_in_production
DASHBOARD_JWT_EXPIRE_MINUTES=720
# Email for the auto-seeded super-admin account (password above)
SUPERADMIN_EMAIL=admin@arteqai.com

# ── Security: CORS + token abuse guard ───────────────────────────
# Comma-separated allowed browser origins. "*" = any (dev only).
# In production set to your real origins, e.g.
#   CORS_ORIGINS=https://arteq.example.com,https://admin.example.com
CORS_ORIGINS=*
# Per-IP cap on /api/v1/livekit/token requests (each spins a billable room).
TOKEN_RATE_LIMIT=12
TOKEN_RATE_WINDOW_SECONDS=60

# ── Internal API (for outbound trigger endpoints) ─────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=your_internal_api_key_here

# ── Staff alerts ──────────────────────────────────────────────────
# SMS the duty manager on bookings, cancellations, emergencies.
# Leave blank to disable.
STAFF_ALERT_PHONE=+91XXXXXXXXXX
STAFF_ALERT_ON_BOOKING=true
STAFF_ALERT_ON_EMERGENCY=true
STAFF_ALERT_ON_CANCEL=true

# ── Scheduler intervals ───────────────────────────────────────────
REMINDERS_ENABLED=true
REMINDER_INTERVAL_SECONDS=900
CONFIRMATIONS_ENABLED=true
CONFIRMATION_LOOP_INTERVAL_SECONDS=3600
CONFIRMATION_DAYS_MIN=6
CONFIRMATION_DAYS_MAX=8
CALLBACKS_ENABLED=true
CALLBACK_LOOP_INTERVAL_SECONDS=300
FOLLOWUPS_ENABLED=true
FOLLOWUP_LOOP_INTERVAL_SECONDS=3600
FOLLOWUP_DAYS_AFTER=3
# Day-of doctor-availability calls (tells patients if their doctor is on time/delayed/unavailable)
DOCTOR_AVAIL_ENABLED=true
DOCTOR_AVAIL_INTERVAL_SECONDS=600
# Resume campaigns whose dialing was interrupted by a restart
CAMPAIGN_RESUME_ENABLED=true
CAMPAIGN_RESUME_INTERVAL_SECONDS=600

# ── Optional feature flags ────────────────────────────────────────
POST_CALL_SMS_ENABLED=false
PATIENT_RECOGNITION_ENABLED=true
AFTER_HOURS_CALLBACK_ENABLED=true
DTMF_ENABLED=true

# ── Advanced / tuning (sensible defaults — change only if needed) ──
# Session & cache
SESSION_TTL_S=300                # in-memory session lifetime (seconds)
CACHE_MAX_SIZE=512               # max entries in the in-memory cache
# Intent handling
INTENT_CONFIDENCE_THRESHOLD=0.50 # min confidence before acting on an intent
MAX_CLARIFICATION_ATTEMPTS=2     # how many times to re-ask before giving up
# Per-call cost estimate shown on the dashboard (paise). Tune to your rate card;
# these drive the displayed ₹/call figure only — they do not change billing.
STT_PAISE_PER_MIN=50             # STT cost per minute of call audio
TTS_PAISE_PER_KCHAR=30           # TTS cost per 1000 characters Arya speaks
LLM_PAISE_PER_TURN=0             # LLM cost per turn (0 = free tier / negligible)

# ── Next.js dashboard (frontend service) ─────────────────────────────────────
# Public origin of the dashboard (used by NextAuth for cookies/callbacks).
NEXTAUTH_URL=http://YOUR_SERVER_IP
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32
# Backend base URL on the compose network (server-side calls from Next.js).
NEXT_PUBLIC_API_BASE=http://app:8000

# Secret admin path for the legacy Alpine dashboard (the Next.js dashboard uses
# real per-user auth at /login, so this is optional now).
ADMIN_PREFIX=/admin
