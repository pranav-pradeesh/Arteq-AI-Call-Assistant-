# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://arteq:arteq@localhost:5432/arteq_hospital
SYNC_DATABASE_URL=postgresql://arteq:arteq@localhost:5432/arteq_hospital

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300          # 5 min default tenant config TTL

# ─── STT — Deepgram (primary) ────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-2          # supports Malayalam
DEEPGRAM_LANGUAGE=ml           # ml = Malayalam
DEEPGRAM_FALLBACK_LANGUAGE=en  # fallback for Manglish

# ─── TTS — Azure (best Malayalam neural voice) ───────────────
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
# Malayalam voice: ml-IN-MidhunNeural (male) / ml-IN-SobhanaNeural (female)
AZURE_TTS_VOICE=ml-IN-SobhanaNeural
# Fallback
AZURE_TTS_FALLBACK_VOICE=ml-IN-MidhunNeural

# ─── LLM — Anthropic (response composition only) ─────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # Haiku for lowest latency
ANTHROPIC_MAX_TOKENS=150       # Keep responses short

# ─── App Settings ────────────────────────────────────────────
APP_ENV=development            # development | staging | production
APP_SECRET_KEY=change_this_in_production
LOG_LEVEL=INFO
PORT=8000

# ─── Dashboard Auth ──────────────────────────────────────────
DASHBOARD_JWT_SECRET=change_this_in_production
DASHBOARD_JWT_EXPIRE_MINUTES=480

# ─── Telephony ───────────────────────────────────────────────
# Twilio (if using Twilio Media Streams)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Exotel (if using Exotel in India)
EXOTEL_SID=your_exotel_sid
EXOTEL_API_KEY=your_exotel_key
EXOTEL_API_TOKEN=your_exotel_token

# ─── Feature Flags ───────────────────────────────────────────
ENABLE_LLM_RESPONSE=true       # Use Claude for response phrasing
ENABLE_FALLBACK_STT=false      # Enable secondary STT on low confidence
STT_CONFIDENCE_THRESHOLD=0.65  # Below this, request clarification
INTENT_CONFIDENCE_THRESHOLD=0.55  # Below this, request clarification
MAX_CLARIFICATION_ATTEMPTS=2   # Before routing to human
